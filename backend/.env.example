HONEYPOT_SHARED_SECRET=your-shared-secret
AI_SERVICE_URL=http://127.0.0.1:9000/ai/score
AI_API_KEY=your-ai-api-key

# Supabase Postgres connection string (Session Pooler or Direct Connection)
# Example: postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@HOST:6543/postgres

# Optional: fallback local sqlite path when DATABASE_URL is not set
DATABASE_PATH=data/honeypot_events.db
